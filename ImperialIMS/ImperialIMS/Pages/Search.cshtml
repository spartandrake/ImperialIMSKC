@page "{query?}"
@model ImperialIMS.Pages.SearchModel
@{
    ViewData["Title"] = "Search";
}

<h2>Search Inventory</h2>

<form method="get" class="mb-4">
    <div class="row g-2 align-items-end">
        <div class="col-md-4">
            <label class="form-label">Item Name</label>
            <input asp-for="Query" class="form-control" placeholder="Search items..." />
        </div>
        <div class="col-md-3">
            <label class="form-label">Storage Facility</label>
            <select asp-for="FacilityId" class="form-select">
                <option value="">All Facilities</option>
                @foreach (var facility in Model.StorageFacilities)
                {
                    <option value="@facility.Id">@facility.Name</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">Category</label>
            <select asp-for="CategoryId" class="form-select">
                <option value="">All Categories</option>
                @foreach (var category in Model.Categories)
                {
                    <option value="@category.Id">@category.Name</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">Status</label>
            <select asp-for="Status" class="form-select">
                <option value="">All Statuses</option>
                <option value="In Stock">In Stock</option>
                <option value="Low Stock">Low Stock</option>
                <option value="Out of Stock">Out of Stock</option>
            </select>
        </div>
        <div class="col-md-1">
            <button type="submit" class="btn btn-primary w-100">Search</button>
        </div>
    </div>
</form>

@if (!Model.Results.Any())
{
    <p class="text-muted">No results found.</p>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Item Name</th>
                <th>Category</th>
                <th>Quantity</th>
                <th>Storage Facility</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var result in Model.Results)
            {
                <tr>
                    <td>@result.ItemName</td>
                    <td>@result.CategoryName</td>
                    <td>@result.StockCount</td>
                    <td>@result.StorageFacilityName</td>
                    <td>
                        @{
                            string badgeClass = result.StockStatus switch
                            {
                                "In Stock" => "bg-success",
                                "Low Stock" => "bg-warning text-dark",
                                _ => "bg-danger"
                            };
                        }
                        <span class="badge @badgeClass">@result.StockStatus</span>
                    </td>
                    <td>
                        <button type="button" class="btn btn-sm btn-outline-primary"
                                data-bs-toggle="modal" data-bs-target="#addToShipmentModal"
                                data-inventory-id="@result.InventoryItemId"
                                data-item-name="@result.ItemName"
                                data-max-stock="@result.StockCount"
                                onclick="prepareModal(this)">
                            Add to Shipment
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="modal fade" id="addToShipmentModal" tabindex="-1" aria-labelledby="addToShipmentModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addToShipmentModalLabel">Add to Shipment</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="AddToShipment">
                <div class="modal-body">
                    <p>Item: <strong id="modalItemName"></strong></p>
                    <input type="hidden" asp-for="AddInventoryItemId" id="modalInventoryItemId" />
                    <div class="mb-3">
                        <label class="form-label">Quantity</label>
                        <input asp-for="AddQuantity" type="number" min="1" id="modalQuantity" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Add to Shipment</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function prepareModal(btn) {
            document.getElementById('modalItemName').textContent = btn.dataset.itemName;
            document.getElementById('modalInventoryItemId').value = btn.dataset.inventoryId;
            document.getElementById('modalQuantity').max = btn.dataset.maxStock;
            document.getElementById('modalQuantity').value = 1;
        }
    </script>
}