@page
@model ImperialIMS.Pages.Admin.Reports.InventoryChangesModel
@{
}
<div class="container">
    <h1>Inventory Changes Report</h1>
    <form method="get">
        <div class="row g-3 align-items-end mb-3">
            <div class="col-md-4">
                <label class="form-label">Storage Facility</label>
                <select asp-for="SelectedFacilityId" class="form-select">
                    <option value="">-- Select Storage Facility --</option>
                    @foreach (var facility in Model.StorageFacilities)
                    {
                        <option value="@facility.Id">@facility.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label asp-for="From" class="form-label">From</label>
                <input asp-for="From" type="date" class="form-control" />
            </div>
            <div class="col-md-3">
                <label asp-for="To" class="form-label">To</label>
                <input asp-for="To" type="date" class="form-control" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Generate Report</button>
            </div>
    </form>

    @if (Model.SelectedFacilityId.HasValue && !Model.ItemsWithHistory.Any())
    {
        <p>No inventory items found for this facility.</p>
    }

    @foreach (var entry in Model.ItemsWithHistory)
    {
        <div class="card mb-4">
            <div class="card-header">
                <strong>@entry.ItemName</strong>
                — Current Stock: @entry.InventoryItem.StockCount
                | Max: @entry.InventoryItem.MaxStockLevel
                | Reorder At: @entry.InventoryItem.ReorderLevel
            </div>
            <div class="card-body">
                @if (!entry.History.Any())
                {
                    <p class="text-muted">No history records.</p>
                }
                else
                {
                    <table class="table table-sm">
                        <tr>
                            <th>Date</th>
                            <th>Old Stock</th>
                            <th>New Stock</th>
                            <th>Change</th>
                            <th>Reason</th>
                        </tr>
                        @foreach (var h in entry.History)
                        {
                            <tr>
                                <td>@h.ChangedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@h.OldStock</td>
                                <td>@h.NewStock</td>
                                <td>@(h.NewStock - h.OldStock)</td>
                                <td>@h.ChangeReason</td>
                            </tr>
                        }
                    </table>
                }
            </div>
        </div>
    }
</div>
