@page "{Id?}"
@model ImperialIMS.Pages.Admin.ItemModel
@{
}
<div class="container">
    <h1>Create a new item</h1>
    <form id="form" method="post" asp-page-handler="CreateOrUpdate" onsubmit="handleSubmit()">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        
        <div class="form-group">
            <label asp-for="Item.Name" class="control-label"></label>
            <input asp-for="Item.Name" value="@Model.NewItem.Name" class="form-control" />
            <span asp-validation-for="Item.Name" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Item.Description" class="control-label"></label>
            <input asp-for="Item.Description" value="@Model.NewItem.Description" class="form-control" />
            <span asp-validation-for="Item.Description" class="text-danger"></span>
        </div>
        <div class="form-group">
            <input class="btn btn-primary" type="submit" />
        </div>
        <input type="hidden" asp-for="@Model.Item.Id" value="@Model.Item.Id" />
    </form>
    <table class="table">
        <tr><th>Name</th><th>Description</th><th>Actions</th></tr>
        @foreach (var item in Model.AllItems)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Description</td>
                <td>
                    <a href="/Admin/Item/@item.Id" class="btn btn-sm btn-warning">Edit</a>
                    @*<button class="btn btn-sm btn-danger" onclick="confirmDelete(@item.Id)">Delete</button>*@
                    <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id"
                          onsubmit="return confirm('Delete @item.Name?')">
                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </table>
</div>